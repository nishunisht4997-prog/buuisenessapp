generator client {
  provider   = "prisma-client-js"
  // Use the binary engine for local/server environments. The "client"
  // engine requires either an adapter or an `accelerateUrl`.
  // Setting engineType = "binary" avoids the need for an adapter when
  // running in environments with a local database connection.
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model User {
  id                 Int        @id @default(autoincrement())
  phone              String     @unique
  createdAt          DateTime   @default(now())
  businesses         Business[]
  isProfileCompleted Boolean    @default(false)
}

model Otp {
  id        Int      @id @default(autoincrement())
  phone     String
  otp       String
  used      Boolean  @default(false)
  expiresAt DateTime
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  status    Boolean  @default(true)
  createdAt DateTime @default(now())

  subCategories SubCategory[]
  businesses    Business[]
}

model SubCategory {
  id         Int      @id @default(autoincrement())
  name       String
  categoryId Int
  status     Boolean  @default(true)
  createdAt  DateTime @default(now())

  category   Category   @relation(fields: [categoryId], references: [id])
  businesses Business[]
}

model State {
  id     Int     @id @default(autoincrement())
  name   String
  status Boolean @default(true)

  districts  District[]
  businesses Business[]
}

model District {
  id      Int     @id @default(autoincrement())
  name    String
  stateId Int
  status  Boolean @default(true)

  state      State      @relation(fields: [stateId], references: [id])
  areas      Area[]
  businesses Business[]
}

model Area {
  id         Int     @id @default(autoincrement())
  name       String
  districtId Int
  status     Boolean @default(true)

  district   District   @relation(fields: [districtId], references: [id])
  businesses Business[]
}

model Business {
  id            Int            @id @default(autoincrement())
  businessCode  String         @unique
  userId        Int
  name          String
  categoryId    Int
  subCategoryId Int
  stateId       Int
  districtId    Int
  areaId        Int
  address       String
  phone         String         @unique
  storeImage    String?
  status        BusinessStatus @default(PENDING)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user        User        @relation(fields: [userId], references: [id])
  category    Category    @relation(fields: [categoryId], references: [id])
  subCategory SubCategory @relation(fields: [subCategoryId], references: [id])
  state       State       @relation(fields: [stateId], references: [id])
  district    District    @relation(fields: [districtId], references: [id])
  area        Area        @relation(fields: [areaId], references: [id])
  products    Product[]
}

enum BusinessStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

model Product {
  id          Int      @id @default(autoincrement())
  businessId  Int
  name        String
  description String?
  quantity    Int
  cost        Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  images ProductImage[]

  business Business @relation(fields: [businessId], references: [id])
}

model ProductImage {
  id        Int    @id @default(autoincrement())
  productId Int
  imageUrl  String
  position  Int

  product Product @relation(fields: [productId], references: [id])
}
